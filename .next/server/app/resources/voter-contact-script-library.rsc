",{"className":"text-xs bg-navy-dark/80 text-cream/50 px-3 py-1 rounded-full border border-gold/10","children":"GOTV"}],["$","span","Door Knock",{"className":"text-xs bg-navy-dark/80 text-cream/50 px-3 py-1 rounded-full border border-gold/10","children":"Door Knock"}],["$","span","Phone Bank",{"className":"text-xs bg-navy-dark/80 text-cream/50 px-3 py-1 rounded-full border border-gold/10","children":"Phone Bank"}],["$","span","Scripts",{"className":"text-xs bg-navy-dark/80 text-cream/50 px-3 py-1 rounded-full border border-gold/10","children":"Scripts"}]]}]]}]]}]]}],["$","section",null,{"className":"section","children":["$","div",null,{"className":"container-custom","children":["$","div",null,{"className":"grid grid-cols-1 lg:grid-cols-3 gap-12","children":[["$","div",null,{"className":"lg:col-span-2","children":["$","div",null,{"className":"prose-custom","dangerouslySetInnerHTML":{"__html":"$13"}}]}],"$L14"]}]}]}]]}],"$L15"]
